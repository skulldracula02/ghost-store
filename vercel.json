{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/login", "dest": "public/login.html" },
    { "src": "/", "dest": "public/index.html" },
    { "src": "/category", "dest": "public/category.html" },
    { "src": "/cart", "dest": "public/cart.html" },
    { "src": "/payment", "dest": "public/payment.html" },
    { "src": "/payment-successful", "dest": "public/payment-successful.html" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
